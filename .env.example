# Copy this file to `.env` (which is gitignored) and fill in your keys.
# NEVER commit real keys. The code reads these names (see configs/provider_policy.yaml
# `api_key_env:`); real shell environment variables take precedence over .env.
#
#   cp .env.example .env   # then edit .env
#
# Authority providers (chair / methodology reviewer / patch reviewer / PI):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
