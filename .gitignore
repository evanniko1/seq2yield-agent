# Data: only manifests/configs are tracked; raw/derived data stay local.
data/raw/*
data/extracted/*
data/processed/*
data/splits/*
data/embeddings/*          # K2a: cached foundation-model embeddings (large, derived; extract locally)
!data/**/.gitkeep
!data/manifests/*.json
!data/manifests/*.csv
!data/manifests/*.md

# Original Colab notebooks are forensic seed material (read-only). They are small and the
# repo owner is the paper author, so they ARE tracked for a self-contained seed reference.
# They are never executed in the pipeline (tests/test_notebooks_not_executed.py).

# Experiment artifacts (large / regenerated). Run-cards are the durable record;
# decide per-policy later which to commit. For now keep the tree, ignore contents.
experiments/runs/*
experiments/accepted/*
experiments/rejected/*
experiments/council_reviews/*
experiments/postmortems/*
experiments/claims/*
experiments/insights/*
!experiments/**/.gitkeep
reports/static/*
reports/dashboard_exports/*
!reports/**/.gitkeep
# but DO track committed reproduction reports (the deliverables)
!reports/static/*_report.md
!reports/static/*_curve.png
!reports/static/*_curve.csv
reports/static/_run.log
reports/model_calls.jsonl

# Secrets — provider API keys never enter the repo.
.env
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
reports/decision_events.jsonl
reports/state/

# local working notes — never commit
NEXT_STEPS.md

# local SQLite read-model (rebuilt via scripts/ingest_history.py)
reports/*.db
reports/*.db-journal
